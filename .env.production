# Production build values. Vite prefers .env.production over .env when building,
# so a local .env pointing at localhost can't leak into a deployed bundle.
#
# Both values below are public identifiers, not secrets — the API base URL is
# the same one the browser calls, and the Google client id is designed to ship
# in client code. Real secrets stay on the backend.

VITE_API_BASE_URL=https://clothingecommerce-backend.onrender.com
VITE_GOOGLE_CLIENT_ID=1024827239097-qboe2h183p46pqau45hv0ckmn3vfb4ar.apps.googleusercontent.com
