# Backend base URL. Falls back to the deployed Render backend when unset,
# so production works without this being configured.
VITE_API_BASE_URL=http://localhost:8000

# Google Sign-In web client id — public identifier, not a secret. Must match
# GOOGLE_CLIENT_ID on the backend (that's the audience the ID token is checked
# against), and the site's origin must be an authorized JavaScript origin in
# the Google Cloud console. Leave empty to hide the Google button entirely.
VITE_GOOGLE_CLIENT_ID=
